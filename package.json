    "telegram",
    "stickers",
    "semantic-search",
    "gemini",
    "embedding",
    "sqlite",
    "vector-search"
  ],
  "author": "Mashiro",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MashiroCodfish/telegram-stickers-brain.git"
  },
  "homepage": "https://github.com/MashiroCodfish/telegram-stickers-brain#readme",
  "bugs": {
    "url": "https://github.com/MashiroCodfish/telegram-stickers-brain/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "better-sqlite3": "^12.6.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "index.js",
